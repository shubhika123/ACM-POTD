/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(NULL) {}
 * };
 */

//https://www.youtube.com/watch?v=vlrxs-LPni4&t=7s - to explain INTUITION in interview
 
//O(), O()
class Solution {
public:
    ListNode *detectCycle(ListNode *head) {
        
        if (head == NULL || head->next == NULL) return NULL;

        ListNode* slow = head;
        ListNode* fast = head;

        while (fast != NULL && fast->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;
            if (slow == fast) break;
        }

        if (slow != fast) return NULL;

        ListNode* P = head;

        while (P != slow) { //eatch video to know reason
            P = P->next;
            slow = slow->next;
        }

        return slow; //or return P; (equal hi ayegi posn agar cycle hui toh)

    }
};
