//hash table - TC -> [unordered map = O(n) and O(n^2) in worst case], [ordered map = O(n logn)], SC -> O(n)
class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        map <int,int> mpp;

        for (int i = 0; i < nums.size(); i++) {
            int num = nums[i];
            int moreNeeded = target - num;
            if (mpp.find(moreNeeded) != mpp.end()) return {mpp[moreNeeded], i}; 
            mpp[num] = i; 
        }
        return {-1, -1};
    }
};
